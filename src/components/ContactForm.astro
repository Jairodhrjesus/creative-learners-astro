---
import { actions } from "astro:actions";
---

<div
    class="bg-white p-8 md:p-10 rounded-[2.5rem] shadow-2xl border border-slate-100 relative overflow-hidden group"
>
    {/* Decorative element */}
    <div
        class="absolute -top-12 -right-12 w-32 h-32 bg-brand-primary/5 rounded-full blur-2xl group-hover:bg-brand-primary/10 transition-colors"
    >
    </div>

    <div class="relative z-10 space-y-6">
        <div class="space-y-2 text-center lg:text-left">
            <h3 class="text-2xl font-black font-heading text-slate-950">
                Schedule a Tour
            </h3>
            <p class="text-sm text-slate-500 font-medium">
                Start your child's journey with us today.
            </p>
        </div>

        <form id="contact-form" class="space-y-4">
            <div>
                <label
                    for="name"
                    class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2 ml-1"
                    >Full Name</label
                >
                <input
                    type="text"
                    id="name"
                    name="name"
                    placeholder="John Doe"
                    required
                    class="w-full bg-slate-50 border-transparent focus:border-brand-primary focus:bg-white focus:ring-0 rounded-2xl py-4 px-6 text-slate-900 font-medium transition-all outline-none border-2"
                />
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-1 gap-4">
                <div>
                    <label
                        for="email"
                        class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2 ml-1"
                        >Email Address</label
                    >
                    <input
                        type="email"
                        id="email"
                        name="email"
                        placeholder="john@example.com"
                        required
                        class="w-full bg-slate-50 border-transparent focus:border-brand-primary focus:bg-white focus:ring-0 rounded-2xl py-4 px-6 text-slate-900 font-medium transition-all outline-none border-2"
                    />
                </div>
                <div>
                    <label
                        for="phone"
                        class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2 ml-1"
                        >Phone Number</label
                    >
                    <input
                        type="tel"
                        id="phone"
                        name="phone"
                        placeholder="(123) 456-7890"
                        class="w-full bg-slate-50 border-transparent focus:border-brand-primary focus:bg-white focus:ring-0 rounded-2xl py-4 px-6 text-slate-900 font-medium transition-all outline-none border-2"
                    />
                </div>
            </div>

            <div>
                <label
                    for="program"
                    class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2 ml-1"
                    >Program of Interest</label
                >
                <select
                    id="program"
                    name="program"
                    class="w-full bg-slate-50 border-transparent focus:border-brand-primary focus:bg-white focus:ring-0 rounded-2xl py-4 px-6 text-slate-900 font-bold transition-all outline-none border-2 appearance-none cursor-pointer"
                >
                    <option value="infant">Infant Program</option>
                    <option value="toddler">Toddler Program</option>
                    <option value="preschool">Preschool Program</option>
                    <option value="pre-k">Pre-K Program</option>
                </select>
            </div>

            <div>
                <label
                    for="message"
                    class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2 ml-1"
                    >Your Message</label
                >
                <textarea
                    id="message"
                    name="message"
                    rows="3"
                    placeholder="Tell us about your child..."
                    required
                    class="w-full bg-slate-50 border-transparent focus:border-brand-primary focus:bg-white focus:ring-0 rounded-2xl py-4 px-6 text-slate-900 font-medium transition-all outline-none border-2 resize-none"
                ></textarea>
            </div>

            <button
                type="submit"
                id="submit-btn"
                class="w-full bg-brand-primary hover:bg-brand-dark text-white font-black py-5 rounded-2xl shadow-xl shadow-brand-primary/20 transition-all active:scale-95 text-lg flex items-center justify-center gap-2"
            >
                <span>Submit Request</span>
            </button>

            <div
                id="form-feedback"
                class="hidden text-center p-3 rounded-xl font-bold text-sm"
            >
            </div>

            <p
                class="text-[10px] text-slate-400 text-center font-bold uppercase tracking-tighter"
            >
                By submitting, you agree to be contacted via phone/email.
            </p>
        </form>
    </div>

    <script>
        import { actions } from "astro:actions";

        const form = document.querySelector("#contact-form") as HTMLFormElement;
        const submitBtn = document.querySelector(
            "#submit-btn",
        ) as HTMLButtonElement;
        const feedback = document.querySelector(
            "#form-feedback",
        ) as HTMLDivElement;

        if (form) {
            form.addEventListener("submit", async (e) => {
                e.preventDefault();

                // Reset feedback
                feedback.classList.add("hidden");
                feedback.classList.remove(
                    "bg-green-100",
                    "text-green-700",
                    "bg-red-100",
                    "text-red-700",
                );

                // Disable button and show loading state
                const originalBtnText = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = `
                    <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span>Sending...</span>
                `;

                const formData = new FormData(form);
                const { data, error } =
                    await actions.sendContactRequest(formData);

                if (error) {
                    console.error(error);
                    // Extract a friendly message from validation errors if they exist
                    let friendlyMessage =
                        "Algo salió mal. Por favor intentalo de nuevo.";

                    if (error.code === "BAD_REQUEST" && "fields" in error) {
                        // If it's a Zod validation error from Astro Actions
                        const fieldErrors = error.fields as Record<
                            string,
                            string[]
                        >;
                        const firstError = Object.values(fieldErrors)[0]?.[0];
                        if (firstError) friendlyMessage = firstError;
                    } else if (error.message) {
                        friendlyMessage = error.message;
                    }

                    feedback.textContent = friendlyMessage;
                    feedback.classList.add("bg-red-100", "text-red-700");
                    feedback.classList.remove("hidden");
                } else if (data && data.success) {
                    feedback.textContent =
                        "Message sent! We will contact you soon.";
                    feedback.classList.add("bg-green-100", "text-green-700");
                    feedback.classList.remove("hidden");
                    form.reset();
                }

                // Reset button
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnText;
            });
        }
    </script>
</div>
